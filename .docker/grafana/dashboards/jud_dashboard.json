          "rawQuery": true,
          "rawSql": "SELECT\n  m.nome_modelo,\n  d.nome AS dataset,\n  COUNT(aj.id_avaliacao) AS total_avaliacoes,\n  ROUND(AVG(aj.nota_atribuida)::numeric, 2) AS nota_media,\n  MIN(aj.nota_atribuida) AS nota_min,\n  MAX(aj.nota_atribuida) AS nota_max\nFROM avaliacoes_juiz aj\nJOIN respostas_atividade_1 ra ON aj.id_resposta_ativa1 = ra.id_resposta\nJOIN modelos m ON ra.id_modelo = m.id_modelo\nJOIN perguntas p ON ra.id_pergunta = p.id_pergunta\nJOIN datasets d ON p.id_dataset = d.id_dataset\nJOIN categorias c ON c.id_categoria = p.id_categoria\nWHERE m.nome_modelo IN ($nome_modelo)\n  AND d.nome IN ($dataset)\n  AND c.nome IN ($categoria)\n  AND COALESCE(p.metadados->>'source_file', '') IN ($source_file)\nGROUP BY m.nome_modelo, d.nome\nORDER BY nota_media DESC",
          "refId": "A",
          "format": "table"
